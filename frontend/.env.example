# 复制本文件为 .env（.env 不会提交 Git）
# cp .env.example .env  然后填入真实值

VITE_SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/你的Infura项目ID

# 阶段 2.4：优先从 Go 后端读列表（失败时自动回退链上 RPC）
VITE_API_URL=http://localhost:8080

# 可选：不填则用 frontend/src/config/contracts.ts 里的默认地址
