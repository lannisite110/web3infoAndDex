# 复制为 .env 或在 shell 中 export（不要提交 .env）
PORT=8080
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.example.mongodb.net/?appName=Cluster0
MONGODB_DB=web3dex

# Phase 4b — Railway MySQL（可用 mysql:// 或 user:pass@tcp(host:port)/db?parseTime=true）
MYSQL_DSN=mysql://USER:PASSWORD@HOST:PORT/railway

# Phase 4b — Upstash Redis（rediss://）
REDIS_URL=rediss://default:PASSWORD@HOST:6379
CACHE_TTL_SEC=60
# auto = 优先 MySQL，失败或缺行时读 MongoDB（推荐，MySQL 到期仍可服务）
STORAGE_READ=auto

# Sepolia — 推荐 Alchemy
CHAIN_ID=11155111
NFT_AUCTION_ADDRESS=0x751D5EDA4EFA561702EFfAe3d6096B28206df575
TEST_NFT_ADDRESS=0x8D8AD875810933D40dba91378c680d39223114c9
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Phase 4b — Etherscan（Sepolia 同一 API Key）
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_KEY

# Phase 4b — OpenSea 占位（可选，后期主网元数据）
# OPENSEA_API_KEY=
# OPENSEA_BASE_URL=https://api.opensea.io/api/v2

# 逗号分隔（生产必配：你的 Vercel 域名 + 本地开发）
# CORS_ORIGINS=https://web3info-and-dex.vercel.app,http://localhost:5173

SYNC_INTERVAL_SEC=15
# 建议填写合约部署区块，用于历史 Bid 事件回填
# NFT_AUCTION_DEPLOY_BLOCK=12345678
